# .env.local 로 복사해 쓰면 .env.development 보다 우선합니다 (비밀·개인 URL 등).
#
# 로컬 기본값은 이미 .env.development 에 있음 → 보통은 npm run dev 만 하면 됨.
# 한 세션만 운영 API로 명시해서 띄울 때: npm run dev:local
#
# 배포(Vercel 등): NEXT_PUBLIC_API_BASE_URL 에 운영/스테이징 API 넣기.
# next build / next start 는 NODE_ENV=production 이라, 변수 미설정 시 client.ts 의 운영 기본 URL 사용.

NEXT_PUBLIC_API_BASE_URL=https://3-39-96-126.sslip.io
NEXT_PUBLIC_FEATURE_TRENDS=true
